#!/usr/bin/env bash
set -euo pipefail

NICO_DIR="/opt/nico"
VENV_DIR="$NICO_DIR/.venv"
CONFIG_DIR="/etc/nico"

case "$1" in
    configure)
        echo "NICO: Setting up virtual environment..."

        # Create venv if missing
        if [ ! -d "$VENV_DIR" ]; then
            python3 -m venv "$VENV_DIR"
        fi
        source "$VENV_DIR/bin/activate"
        pip install --upgrade pip wheel setuptools

        # Upgrade / reinstall the package inside the venv
        pip install "$NICO_DIR"

        # Ensure /etc/nico config dir and .env
        mkdir -p "$CONFIG_DIR"
        if [ ! -f "$CONFIG_DIR/.env" ]; then
            cp "$NICO_DIR/.env.example" "$CONFIG_DIR/.env"
            echo "NICO: Created /etc/nico/.env — edit it with your API keys:"
            echo "       sudo nano /etc/nico/.env"
        fi

        # Enable systemd service (but don't start — user must configure first)
        if systemctl --help >/dev/null 2>&1; then
            cp "$NICO_DIR/nico.service" /etc/systemd/system/nico.service 2>/dev/null || true
            systemctl daemon-reload
            systemctl enable nico.service 2>/dev/null || true
            echo "NICO: systemd service installed and enabled."
            echo "       Configure your API keys in /etc/nico/.env, then:"
            echo "       sudo systemctl start nico"
        fi

        echo ""
        echo "╔══════════════════════════════════════════════════╗"
        echo "║          NICO — Installation Complete           ║"
        echo "╠══════════════════════════════════════════════════╣"
        echo "║ 1. Edit your API keys:                          ║"
        echo "║    sudo nano /etc/nico/.env                     ║"
        echo "║                                                 ║"
        echo "║ 2. Start NICO:                                  ║"
        echo "║    sudo systemctl start nico                    ║"
        echo "║                                                 ║"
        echo "║ 3. Or run manually:                             ║"
        echo "║    /opt/nico/.venv/bin/python /opt/nico/main.py ║"
        echo "║                                                 ║"
        echo "║ 4. View logs:                                   ║"
        echo "║    sudo journalctl -u nico -f                   ║"
        echo "╚══════════════════════════════════════════════════╝"
        echo ""
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        exit 0
        ;;

    *)
        echo "postinst called with unknown argument: $1" >&2
        exit 1
        ;;
esac
