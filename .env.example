# NICO Environment Configuration
# Copy this file to .env, fill in your Google Assistant settings

# --- Google Assistant SDK (free, built-in web search, weather, etc.) ---
NICO_DEFAULT_PROVIDER=google_assistant
GOOGLE_CREDENTIALS_FILE=/home/pi/nico/credentials.json
GOOGLE_ASSISTANT_DEVICE_MODEL_ID=nico-assistant-v1
GOOGLE_ASSISTANT_DEVICE_ID=nico-device-1
GOOGLE_ASSISTANT_LANGUAGE_CODE=en-IN

# --- STT: Google Web Speech API (free, no key needed, requires internet) ---
# Or use: groq (free tier, needs GROQ_API_KEY), whisper_openai (needs OPENAI_API_KEY)
STT_PROVIDER=google_free

# --- TTS: pyttsx3 (free, offline, no API key) ---
# Or use: gtts (free, online), openai (paid)
TTS_PROVIDER=pyttsx3

# --- Wake Word ---
# Auto-selects: Picovoice (if PICOVOICE_ACCESS_KEY set) → OpenWakeWord (if installed) → energy fallback
WAKE_WORD=hey nico

# --- Voice / Audio ---
NICO_ENABLE_VOICE=true
NICO_ASSISTANT_NAME=NICO
NICO_LOG_LEVEL=INFO
NICO_ENABLE_MEMORY=false
NICO_ENABLE_TOOLS=true
NICO_ALLOW_SYSTEM_CONTROL=false
