# NICO Environment Configuration
# Copy this file to .env and fill in your keys

# --- AI Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Google Integrations ---
GOOGLE_CREDENTIALS_FILE=credentials.json

# --- Weather ---
OPENWEATHER_API_KEY=

# --- Voice / Audio (optional) ---
PICOVOICE_ACCESS_KEY=
VAD_SENSITIVITY=0.5
VAD_FRAME_MS=30
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# --- NICO Settings ---
NICO_LOG_LEVEL=INFO
NICO_DEFAULT_PROVIDER=openai
NICO_ASSISTANT_NAME=NICO
NICO_ENABLE_TOOLS=true
NICO_ENABLE_MEMORY=true
NICO_FILES_ROOT=./nico_files
NICO_ALLOW_SYSTEM_CONTROL=false

# --- Google Assistant (for smart-home device control) ---
GOOGLE_ASSISTANT_DEVICE_MODEL_ID=
GOOGLE_ASSISTANT_DEVICE_ID=
GOOGLE_ASSISTANT_TOKEN_FILE=~/.nico/assistant_token.json
